# Expo Mobile Environment Configuration Template
# 
# Copy this file to .env and replace the placeholder values with your local network settings.
# DO NOT commit .env to version control (it contains sensitive IP/URL data)

# Django Backend API Base URL
# Replace with your machine's local IPv4 address and Django port
# Format: http://<LOCAL_IPv4>:8000/api/
# Example: http://192.168.1.15:8000/api/
EXPO_PUBLIC_API_URL=http://192.168.X.X:8000/api/
